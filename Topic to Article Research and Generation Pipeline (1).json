      "position": [
        -2272,
        80
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Topic: {{ $(\"Input Topic\").item.json.topic }}\n\nKeywords: {{ $json.output }}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are a search optimization assistant. Select the best 3 search queries that will return high-quality blog/article results."
        }
      },
      "id": "d5b0d0c7-309e-402c-b16b-2a0529c7508c",
      "name": "Search Query Builder Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -1920,
        80
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json[\"output.search_queries\"] }}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are a research assistant. Use the search tool to find information about the given query. The tool will return summaries and content. Extract the 3 most relevant content summaries and return them as a JSON object with an array under the key \"summaries\". Example: {\"summaries\": [\"summary1\", \"summary2\", \"summary3\"]}"
        }
      },
      "id": "688cb1b9-d0f9-4f04-a267-e159b25cb439",
      "name": "Search Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -1296,
        80
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json[\"output.summaries\"] }}",
        "options": {
          "systemMessage": "You are a content cleaner. Review the following summary and ensure it is clean, well-structured, and focused on the main points. Remove any irrelevant information and return clean readable text only."
        }
      },
      "id": "f2f8b078-58de-4bfe-a81d-a1e14e024c61",
      "name": "Content Cleaner Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -656,
        80
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.articles }}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are a research analyst. Extract key insights (bullet points), common themes across sources, unique ideas from each source, important data/statistics, and content gaps or missing angles from the provided articles."
        }
      },
      "id": "60a96479-7fb2-466a-a4d1-0467b6b42cff",
      "name": "Summarization Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -80,
        80
      ]
    },
