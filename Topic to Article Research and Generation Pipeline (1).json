      "parameters": {
        "promptType": "define",
        "text": "={{ $json.topic }}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are an SEO strategist. Generate 10 high-intent search keywords, 5 long-tail keywords, and 5 \"People Also Ask\" style questions based on the input topic."
        }
      },
      "id": "7c5c901b-7917-4f6b-8fad-aeda3191fd13",
      "name": "Keyword Expansion Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
