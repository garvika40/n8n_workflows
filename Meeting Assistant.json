    {
      "parameters": {
        "jsCode": "const meetings = $input.all().map(i => i.json).filter(m => !m.error);\n\nconst sections = meetings.map(m => {\n\n  const output = m.output || [];\n\n  // Text is at output[0].content[0].text  ← this is the fix\n  const rawText = output\n    .filter(o => o.type === 'message')\n    .flatMap(o => o.content || [])\n    .filter(c => c.type === 'output_text')\n    .map(c => c.text)\n    .join('\\n')\n    .trim();\n\n  const cleanText = rawText\n    .replace(/\\*\\*(.+?)\\*\\*/g, '$1')\n    .replace(/### /g, '')\n    .replace(/## /g, '')\n    .replace(/# /g, '')\n    .replace(/\\n   - /g, '\\n  • ')\n    .replace(/\\n- /g, '\\n  • ');\n\n  const title = m.title || 'Untitled meeting';\n  const summary = m.summary || '';\n\n  return '📅 ' + title + (summary ? '\\n' + summary : '') + '\\n\\n' + cleanText;\n\n}).join('\\n\\n---\\n\\n');\n\nconst date = new Date().toDateString();\nconst count = meetings.length;\nconst subject = 'Meeting tasks — ' + date + ' (' + count + ' meetings)';\nconst body = 'Daily meeting summary — ' + date + '\\n\\n' + sections;\n\nreturn [{ json: { subject, body, count } }];"
      },
